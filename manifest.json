{
  "manifest_version": 3,
  "name": "SnapText OCR",
  "version": "1.0.0",
  "description": "Selecione qualquer área da tela e extraia o texto em segundos. OCR 100% local com Tesseract.js — sem envio de dados.",

  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "SnapText OCR — Extrair texto da tela",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "libs/worker.min.js",
        "libs/tesseract-core-simd.wasm.js",
        "libs/tesseract-core.wasm.js",
        "libs/tesseract-core-simd-lstm.wasm.js",
        "libs/tesseract-core-lstm.wasm.js",
        "libs/tessdata/por.traineddata.gz",
        "libs/tessdata/eng.traineddata.gz",
        "libs/tessdata/spa.traineddata.gz",
        "libs/tessdata/fra.traineddata.gz",
        "libs/tessdata/deu.traineddata.gz"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
